# Environment variables for Heroku deployment

# Flask settings
FLASK_ENV=production
FLASK_APP=tegallmembar.app

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# Server settings
HOST=0.0.0.0
PORT=5000

# Debug mode (set to False in production)
DEBUG=False

# Additional settings
APP_NAME=Tegallmembar
